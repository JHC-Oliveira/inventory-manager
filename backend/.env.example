APP_NAME="Inventory Manager"
APP_ENV=development
DEBUG=true
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_32_CHAR_STRING

POSTGRES_USER=inventoryuser
POSTGRES_PASSWORD=CHANGE_THIS
POSTGRES_DB=inventorydb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://inventoryuser:CHANGE_THIS@postgres:5432/inventorydb

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

RABBITMQ_USER=guest
RABBITMQ_PASSWORD=CHANGE_THIS
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_URL=amqp://guest:CHANGE_THIS@rabbitmq:5672/

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
ALLOWED_ORIGINS=http://localhost:3000